# SPDX-License-Identifier: MPL-2.0
# 0patch-lsa-sentinel — Editor Configuration
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.adoc]
trim_trailing_whitespace = false

[*.rs]
indent_size = 4

[*.zig]
indent_size = 4

[*.ada]
indent_size = 3

[*.adb]
indent_size = 3

[*.ads]
indent_size = 3

[*.gpr]
indent_size = 3

[*.idr]
indent_size = 2

[*.ipkg]
indent_size = 2

[*.a2ml]
indent_size = 2

[Justfile]
indent_style = space
indent_size = 4
